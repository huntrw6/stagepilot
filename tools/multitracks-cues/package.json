{
  "name": "@stagepilot/multitracks-cues",
  "version": "0.1.0",
  "private": true,
  "description": "Standalone, safe MultiTracks Playback MIDI cue automation for StagePilot",
  "type": "module",
  "bin": {
    "stagepilot-cues": "dist/cli/main.js"
  },
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "config.example.json"
  ],
  "engines": {
    "node": ">=22 <25"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsx src/cli/main.ts",
    "lint": "eslint .",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "local-install": "npm run build && npm link"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "ajv": "8.20.0",
    "commander": "14.0.2",
    "cross-keychain": "1.1.0",
    "open": "11.0.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "9.39.2",
    "@types/node": "24.10.1",
    "eslint": "9.39.2",
    "globals": "16.5.0",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.52.0",
    "vitest": "4.1.0"
  }
}
