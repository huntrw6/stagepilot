# Local-only binding is the safe default. Use 0.0.0.0 only after assessing LAN access.
STAGEPILOT_HOST=127.0.0.1
STAGEPILOT_PORT=8765
STAGEPILOT_LOG_LEVEL=INFO
STAGEPILOT_DEMO_MODE=true
# Leave these true for a fully simulated demo. Set either to false to let the
# corresponding real integration run while the demo service plan remains loaded.
STAGEPILOT_DEMO_SIMULATE_MIDI=true
STAGEPILOT_DEMO_SIMULATE_PROPRESENTER=true

# Planning Center Personal Access Token settings are consumed only by the backend.
# STAGEPILOT_PCO_APP_ID=
# STAGEPILOT_PCO_SECRET=
# STAGEPILOT_PCO_SERVICE_TYPE_ID=
STAGEPILOT_PCO_LOOKAHEAD_DAYS=30
STAGEPILOT_PCO_TIMEOUT_SECONDS=10
STAGEPILOT_PCO_USER_AGENT="StagePilot/0.9.7 (https://github.com/huntrw6/stage-pilot)"
STAGEPILOT_TIMEZONE=America/Los_Angeles

# Playback MIDI input is local and needs no credentials. It is disabled by
# default. For mixed demo/real testing, also set
# STAGEPILOT_DEMO_SIMULATE_MIDI=false.
STAGEPILOT_MIDI_ENABLED=false
# Startup default. A dashboard selection overrides it only for the current
# backend session and is discarded when the backend stops.
# STAGEPILOT_MIDI_INPUT_NAME=
STAGEPILOT_MIDI_CHANNEL=1
STAGEPILOT_MIDI_START_NEXT_NOTE=100
STAGEPILOT_MIDI_RESTART_CURRENT_NOTE=101
STAGEPILOT_MIDI_PREVIOUS_NOTE=102
STAGEPILOT_MIDI_NEXT_NOTE=103
STAGEPILOT_MIDI_RELOAD_PLAN_NOTE=104
STAGEPILOT_MIDI_STOP_TIMER_NOTE=105
STAGEPILOT_MIDI_DEBOUNCE_MS=250

# ProPresenter HTTP API. To use a demo Planning Center plan with a real timer,
# set STAGEPILOT_DEMO_SIMULATE_PROPRESENTER=false as well.
STAGEPILOT_PROPRESENTER_ENABLED=false
STAGEPILOT_PROPRESENTER_HOST=127.0.0.1
STAGEPILOT_PROPRESENTER_PORT=1025
STAGEPILOT_PROPRESENTER_TIMER_NAME="Song Countdown"
STAGEPILOT_PROPRESENTER_TIMEOUT_SECONDS=3

# ProPresenter connection supervision
STAGEPILOT_PROPRESENTER_RECONNECT_INITIAL_SECONDS=1
STAGEPILOT_PROPRESENTER_RECONNECT_MAX_SECONDS=30
STAGEPILOT_PROPRESENTER_HEALTH_CHECK_SECONDS=10
