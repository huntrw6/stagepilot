{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "StagePilot",
  "version": "0.1.0",
  "identifier": "org.stagepilot.desktop",
  "build": {
    "beforeDevCommand": "npm --prefix ../frontend run dev -- --host 127.0.0.1",
    "devUrl": "http://127.0.0.1:5173",
    "beforeBuildCommand": "npm --prefix ../frontend run build",
    "frontendDist": "../../frontend/dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "StagePilot",
        "width": 1440,
        "height": 960,
        "minWidth": 1024,
        "minHeight": 700,
        "maxWidth": 1700,
        "maxHeight": 2560,
        "decorations": false,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://127.0.0.1:* ws://127.0.0.1:*; font-src 'self' data:; img-src 'self' data:; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": false,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
