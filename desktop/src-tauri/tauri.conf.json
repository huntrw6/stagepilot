{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "StagePilot",
  "version": "0.1.0",
  "identifier": "org.stagepilot.app",
  "build": {
    "beforeDevCommand": "npm --prefix ../frontend run dev -- --host 127.0.0.1",
    "devUrl": "http://127.0.0.1:5173",
    "beforeBuildCommand": "npm --prefix ../frontend run build",
    "frontendDist": "../../frontend/dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "StagePilot",
        "width": 1440,
        "height": 960,
        "minWidth": 1024,
        "minHeight": 700,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://127.0.0.1:8765 ws://127.0.0.1:8765 http://127.0.0.1:5173 ws://127.0.0.1:5173; font-src 'self' data:; img-src 'self' data:; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": false,
    "targets": "all"
  }
}
