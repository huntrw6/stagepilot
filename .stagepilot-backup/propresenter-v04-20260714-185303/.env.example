# StagePilot runtime settings
#
# Copy this file to .env only when using an environment loader. StagePilot does
# not load .env files implicitly; export the values or use the included
# scripts/run-demo-hardware.ps1 helper for the mixed demo/hardware test.

# Keep the API loopback-only unless remote access has been deliberately secured.
STAGEPILOT_HOST=127.0.0.1
STAGEPILOT_PORT=8765
STAGEPILOT_LOG_LEVEL=INFO
STAGEPILOT_DEMO_MODE=true

# Leave these true for the original all-simulated demo. Set either to false to
# run that real integration while retaining the demo service plan.
STAGEPILOT_DEMO_SIMULATE_MIDI=true
STAGEPILOT_DEMO_SIMULATE_PROPRESENTER=true

# Planning Center Personal Access Token settings. Keep the credential values
# empty in this tracked example and set them only in an ignored local environment.
# Set STAGEPILOT_DEMO_MODE=false before using the production integration.
# STAGEPILOT_PCO_APP_ID=
# STAGEPILOT_PCO_SECRET=
# STAGEPILOT_PCO_SERVICE_TYPE_ID=

# Prefer today's plan, then search this many future local dates for the nearest
# upcoming service plan.
STAGEPILOT_PCO_LOOKAHEAD_DAYS=30
STAGEPILOT_PCO_TIMEOUT_SECONDS=10
STAGEPILOT_PCO_USER_AGENT="StagePilot/0.1.0 (https://github.com/huntrw6/stage-pilot)"
STAGEPILOT_TIMEZONE=America/Los_Angeles

# Playback MIDI input is local and needs no credentials. For mixed demo/real
# testing, set STAGEPILOT_DEMO_SIMULATE_MIDI=false too.
STAGEPILOT_MIDI_ENABLED=false
# STAGEPILOT_MIDI_INPUT_NAME=
STAGEPILOT_MIDI_CHANNEL=1
STAGEPILOT_MIDI_START_NEXT_NOTE=100
STAGEPILOT_MIDI_RESTART_CURRENT_NOTE=101
STAGEPILOT_MIDI_PREVIOUS_NOTE=102
STAGEPILOT_MIDI_NEXT_NOTE=103
STAGEPILOT_MIDI_RELOAD_PLAN_NOTE=104
STAGEPILOT_MIDI_STOP_TIMER_NOTE=105
STAGEPILOT_MIDI_DEBOUNCE_MS=250

# ProPresenter HTTP API. For mixed demo/real testing, set
# STAGEPILOT_DEMO_SIMULATE_PROPRESENTER=false too.
STAGEPILOT_PROPRESENTER_ENABLED=false
STAGEPILOT_PROPRESENTER_HOST=127.0.0.1
STAGEPILOT_PROPRESENTER_PORT=1025
STAGEPILOT_PROPRESENTER_TIMER_NAME="Song Countdown"
STAGEPILOT_PROPRESENTER_TIMEOUT_SECONDS=3
