# Local-only binding is the safe default. Use 0.0.0.0 only after assessing LAN access.
STAGEPILOT_HOST=127.0.0.1
STAGEPILOT_PORT=8765
STAGEPILOT_LOG_LEVEL=INFO
STAGEPILOT_DEMO_MODE=true

# Planning Center Personal Access Token settings are consumed only by the backend.
# STAGEPILOT_PCO_APP_ID=
# STAGEPILOT_PCO_SECRET=
# STAGEPILOT_PCO_SERVICE_TYPE_ID=
STAGEPILOT_PCO_LOOKAHEAD_DAYS=30
STAGEPILOT_PCO_TIMEOUT_SECONDS=10
STAGEPILOT_PCO_USER_AGENT="StagePilot/0.1.0 (https://github.com/huntrw6/stage-pilot)"
STAGEPILOT_TIMEZONE=America/Los_Angeles

# Playback MIDI input is local and needs no credentials. It is disabled by
# default and is currently registered only when demo mode is false.
STAGEPILOT_MIDI_ENABLED=false
# Startup default. A dashboard selection overrides it only for the current
# backend session and is discarded when the backend stops.
# STAGEPILOT_MIDI_INPUT_NAME=
STAGEPILOT_MIDI_CHANNEL=1
STAGEPILOT_MIDI_START_NEXT_NOTE=112
STAGEPILOT_MIDI_RESTART_CURRENT_NOTE=113
STAGEPILOT_MIDI_PREVIOUS_NOTE=114
STAGEPILOT_MIDI_NEXT_NOTE=115
STAGEPILOT_MIDI_RELOAD_PLAN_NOTE=116
STAGEPILOT_MIDI_STOP_TIMER_NOTE=117
STAGEPILOT_MIDI_DEBOUNCE_MS=250
