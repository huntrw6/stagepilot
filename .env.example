# StagePilot Milestone 1 runtime settings
# Copy this file to .env for local development. The application does not load
# .env files implicitly; export the values or use your preferred local env tool.

# Keep the API loopback-only unless remote access has been deliberately secured.
STAGEPILOT_HOST=127.0.0.1
STAGEPILOT_PORT=8765
STAGEPILOT_LOG_LEVEL=INFO
STAGEPILOT_DEMO_MODE=true

# Reserved for the Planning Center milestone. They are documented now so real
# credentials never need to be added to a tracked file; Milestone 1 ignores them.
# STAGEPILOT_PCO_APP_ID=
# STAGEPILOT_PCO_SECRET=
# STAGEPILOT_PCO_SERVICE_TYPE_ID=
# STAGEPILOT_TIMEZONE=America/Los_Angeles
